rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isHelper() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/helpers/$(request.auth.uid));
    }

    function isPlatformUser() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/platform_users/$(request.auth.uid));
    }

    function isPlatformAdmin() {
      return isPlatformUser() &&
        get(/databases/$(database)/documents/platform_users/$(request.auth.uid)).data.role == 'platform_admin';
    }

    function isPlatformCollection(collection) {
      return collection in [
        'actors',
        'intake_submissions',
        'capacity_cards',
        'capacity_changes',
        'vouches',
        'needs',
        'pattern_alerts',
        'urgency_alerts',
        'collaborations',
        'joint_operations',
        'shared_tasks',
        'flash_assessments',
        'assessment_snapshots',
        'sector_plans',
        'gap_analyses',
        'message_threads',
        'messages',
        'community_feedback',
        'outcome_reports',
        'network_outcomes',
        'platform_stats',
        'zones'
      ];
    }

    // Rate limiting: check timestamp-based rules
    function isRecentWrite() {
      return request.time < resource.data.createdAt + duration.value(1, 's');
    }

    // ---- REQUESTS ----
    // Public can read non-sensitive fields of open requests
    // Anyone can create (including anonymous users)
    // Only admins can update
    match /requests/{requestId} {
      allow read: if true; // Public browsing of requests
      allow create: if true; // Anonymous submissions allowed
      allow update: if isAdmin();
      allow delete: if isAdmin();

      // Private subcollection: contact info
      // Only admins and the claimed helper can read
      match /private/{docId} {
        allow read: if isAdmin() ||
          (isHelper() && resource != null &&
           get(/databases/$(database)/documents/requests/$(requestId)).data.claimedBy == request.auth.uid);
        allow create: if true; // Created during request submission
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    // ---- PLATFORM DATA ----
    // Coordination platform data is public read-only in the app.
    // Writes are performed through trusted tooling, not client SDKs.
    match /{collection}/{docId} {
      allow read: if isPlatformCollection(collection);
      allow write: if false;
    }

    // ---- HELPERS ----
    // Helpers can read their own profile
    // Anyone can create (registration)
    // Helpers can update their own profile, admins can update any
    match /helpers/{helperId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == helperId;
      allow update: if (isAuthenticated() && request.auth.uid == helperId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ---- PLATFORM USERS ----
    // Platform users are private identity mappings for Shabaka org/admin accounts.
    match /platform_users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || isPlatformAdmin());
      allow write: if false;
    }

    // ---- CLAIMS ----
    // Helpers can create claims
    // Admins and involved parties can read
    match /claims/{claimId} {
      allow read: if isAuthenticated();
      allow create: if isHelper();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---- ADMINS ----
    // Only admins can read admin docs (for auth check)
    match /admins/{adminId} {
      allow read: if isAuthenticated() && request.auth.uid == adminId;
      allow write: if false; // Admins are created manually or via Cloud Functions
    }

    // ---- STATS ----
    // Public can read stats (single document, very efficient)
    // Only server/admin can write
    match /stats/{docId} {
      allow read: if true;
      allow write: if isAuthenticated(); // In production, restrict to Cloud Functions
    }

    // ---- CONTACTS ----
    // Public directory of area contacts
    match /contacts/{contactId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---- SHELTERS ----
    // Public can read shelter data (cached from external source)
    // Only authenticated users can write (caching layer)
    match /shelters/{shelterId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Shelter cache metadata
    match /shelters_cache/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ---- AUDIT LOGS ----
    // Only admins can read audit logs
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated(); // Created by system on actions
      allow update, delete: if false; // Immutable
    }
  }
}

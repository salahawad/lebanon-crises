{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    ".test-artifacts/next/playwright-39835/types/**/*.ts",
    ".test-artifacts/next/playwright-39835/dev/types/**/*.ts",
    ".test-artifacts/next/playwright-46409/types/**/*.ts",
    ".test-artifacts/next/playwright-46409/dev/types/**/*.ts",
    ".test-artifacts/next/playwright-35369/types/**/*.ts",
    ".test-artifacts/next/playwright-35369/dev/types/**/*.ts",
    ".test-artifacts/next/playwright-34881/types/**/*.ts",
    ".test-artifacts/next/playwright-34881/dev/types/**/*.ts",
    ".test-artifacts/next/playwright-36365/types/**/*.ts",
    ".test-artifacts/next/playwright-36365/dev/types/**/*.ts",
    ".test-artifacts/next/playwright-41927/types/**/*.ts",
    ".test-artifacts/next/playwright-41927/dev/types/**/*.ts",
    ".test-artifacts/next/playwright-38897/types/**/*.ts",
    ".test-artifacts/next/playwright-38897/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
